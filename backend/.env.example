# =========================================================================
# Backend Environment Variables Template
# Copy this file to .env for local configurations
# =========================================================================

# The application environment: 'development', 'staging', or 'production'
# Controls reload server flags and worker counts dynamically.
APP_ENV=development

# The bind host address for the FastAPI Uvicorn/Gunicorn runner.
# - Production: 0.0.0.0 (listens on all interfaces in container)
# - Local: 127.0.0.1 or 0.0.0.0
HOST=0.0.0.0

# The bind port for the FastAPI server inside the container.
PORT=8000

# CORS Allowed Origins
# - Production: Set to your frontend IP/domain (e.g. http://54.210.45.12) or '*' for fully public access.
# - Multiple origins can be comma-separated (e.g., http://domain.com,http://another.com)
ALLOWED_ORIGINS=*

# MongoDB Connection String
# - Local: mongodb://localhost:27017
# - Production Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/database_name?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017

# MongoDB Database Name
DATABASE_NAME=app_db

# Security & Session Settings
# Run `openssl rand -hex 32` to generate a strong key
JWT_SECRET=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Google OAuth Client Credentials (optional, if using Google login)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=

# The name of the project
PROJECT_NAME=Hackathon Starter

# Optional legacy variables (still supported as fallbacks)
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000
# BACKEND_WORKERS=4
