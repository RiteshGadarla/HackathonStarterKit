{
  "name": "project-root",
  "version": "1.0.0",
  "description": "Full-Stack Hackathon Template (React + FastAPI + MongoDB)",
  "scripts": {
    "install:linux": "npm install && npm install --prefix frontend && (cd backend && python3 -m venv venv && venv/bin/pip install -r requirements.txt)",
    
    "install:windows": "npm install && npm install --prefix frontend && cd backend && python -m venv venv && venv\\Scripts\\pip install -r requirements.txt",

    "activate:linux": "bash -c 'cd backend && source venv/bin/activate && exec $SHELL'",
    
    "activate:windows": "cmd /k \"cd backend && venv\\Scripts\\activate\"",

    "backend:linux": "cd backend && ./venv/bin/python run.py development",
    
    "backend:windows": "cd backend && venv\\Scripts\\python run.py development",

    "frontend": "cd frontend && npm run dev",

    "dev:linux": "concurrently \"npm run backend:linux\" \"npm run frontend\"",
    
    "dev:windows": "concurrently \"npm run backend:windows\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}