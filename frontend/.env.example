# Frontend API base URL
# Leave empty or omit to use Vite proxy (recommended for development)
# Set to full URL for direct backend access (e.g., https://api.yourdomain.com/api)
VITE_API_BASE_URL=

# Backend proxy target for Vite dev server
# This is where the Vite proxy forwards /api requests during development
VITE_PROXY_TARGET=http://localhost:8000

VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_APP_NAME=Hackathon Starter
