# =========================================================================
# Frontend Environment Variables Template
# Copy this file to .env or .env.local for local configurations
# =========================================================================

# The API base URL of the backend.
# - Production: Set to your Backend EC2 HTTP URL (e.g., http://54.210.45.12 or http://api.yourdomain.com)
# - Development: Leave empty or omit to use the Vite dev server proxy (recommended)
VITE_API_BASE_URL=http://your-backend-ip-or-domain

# The application environment: 'development', 'staging', or 'production'
VITE_APP_ENV=development

# Google OAuth Client ID (optional, if using Google login)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# The name of the application
VITE_APP_NAME=Hackathon Starter

# Backend proxy target for local development (only used by Vite dev server)
VITE_PROXY_TARGET=http://localhost:8000
