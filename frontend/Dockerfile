# ── Stage 1: Build the Vite/React Application ─────────────────────────
FROM node:20-alpine AS build

WORKDIR /app

# Copy package files first to leverage Docker layer caching
COPY package*.json ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

# Copy all source files
COPY . .

# Set build-time arguments for Vite/React environment configuration
ARG VITE_API_BASE_URL=/api
ARG VITE_APP_ENV=production
ARG VITE_GOOGLE_CLIENT_ID=""
ARG VITE_APP_NAME="Hackathon Starter"

# Convert build-time arguments to environment variables for npm run build
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_APP_ENV=$VITE_APP_ENV
ENV VITE_GOOGLE_CLIENT_ID=$VITE_GOOGLE_CLIENT_ID
ENV VITE_APP_NAME=$VITE_APP_NAME

# Build the static application
RUN npm run build

# ── Stage 2: Serve the Static Assets with Nginx ───────────────────────
FROM nginx:1.25-alpine

# Copy compiled HTML, CSS, JS assets from build stage
COPY --from=build /app/dist /usr/share/nginx/html

# Copy custom Nginx configuration
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy runtime entrypoint script to dynamicize environment configs
COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

EXPOSE 80

ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["nginx", "-g", "daemon off;"]
